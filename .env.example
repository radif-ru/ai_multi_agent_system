# --- Telegram ---
# Токен бота, полученный у @BotFather. Обязательная переменная.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Максимальный размер файла для скачивания из Telegram (МБ).
TELEGRAM_MAX_FILE_MB=20

# --- Ollama (LLM) ---
# Базовый URL локального Ollama API (обычно http://localhost:11434).
OLLAMA_BASE_URL=http://localhost:11434
# Модель для агентного цикла (thought→action→observation). Должна
# присутствовать в OLLAMA_AVAILABLE_MODELS. Из ТЗ — qwen3.5:4b.
OLLAMA_DEFAULT_MODEL=qwen3.5:4b
# Список доступных моделей через запятую (теги из `ollama list`).
OLLAMA_AVAILABLE_MODELS=qwen3.5:4b,qwen3.5:0.8b,qwen3.6:35b,nomic-embed-text:latest,deepseek-r1:1.5b,llava:7b,gpt-oss:20b,kimi-k2.6:cloud
# Таймаут на один запрос к Ollama, секунды.
OLLAMA_TIMEOUT=120

# --- Ollama (Embeddings) ---
# Модель для семантической памяти (RAG). nomic-embed-text по умолчанию.
EMBEDDING_MODEL=nomic-embed-text
# Размерность вектора, должна соответствовать выбранной модели.
EMBEDDING_DIMENSIONS=768

# --- Agent loop ---
# Максимальное число итераций цикла thought→action→observation на одну задачу.
# Защита от бесконечного цикла, см. _docs/agent-loop.md §4.
AGENT_MAX_STEPS=10
# Максимальная длина ответа модели, который мы согласимся парсить как JSON
# (защита от мусора при неправильно отформатированном выводе).
AGENT_MAX_OUTPUT_CHARS=8000

# --- Memory (краткосрочная, in-memory) ---
# Жёсткий лимит на количество сообщений в истории одного пользователя.
# При превышении самые старые сообщения удаляются (FIFO).
HISTORY_MAX_MESSAGES=20
# Порог количества сообщений, при достижении которого старая часть истории
# сжимается LLM в краткое резюме. Должно быть > 0 и <= HISTORY_MAX_MESSAGES.
HISTORY_SUMMARY_THRESHOLD=10
# Верхняя страховка размера полного лога сессии (см. _docs/memory.md §2.5).
# Полный лог — параллельный append-only буфер, который cmd_new передаёт в
# Archiver. Защищает от аномально длинных сессий без /new. При переполнении
# отбрасывается голова и пишется WARNING.
SESSION_LOG_MAX_MESSAGES=1000
# System prompt для in-memory суммаризации (порог в одной сессии).
SUMMARIZATION_PROMPT=Кратко и точно резюмируй ключевые факты и решения из этого диалога в 2–4 предложениях. Ответ — только текст резюме, без вступлений.
# Порог числа сообщений для перехода в map-reduce при суммаризации длинных
# логов сессии (см. _docs/memory.md §3.3). При len(messages) > порога:
# режем лог на батчи по N сообщений, суммаризуем каждый (map), затем сводим
# мини-саммари в одно итоговое (reduce).
SUMMARIZER_CHUNK_MESSAGES=30

# --- Memory (долгосрочная, sqlite-vec) ---
# Путь к файлу SQLite-БД с расширением sqlite-vec.
# Каталог создаётся автоматически. См. _docs/memory.md.
MEMORY_DB_PATH=data/memory.db
# Размер чанка саммари в символах при /new. См. _docs/memory.md §3.
MEMORY_CHUNK_SIZE=1500
# Перекрытие соседних чанков (символов).
MEMORY_CHUNK_OVERLAP=150
# Сколько чанков возвращать при поиске по семантической памяти.
MEMORY_SEARCH_TOP_K=5
# Авто-подгрузка архива в первый ход новой сессии (см. _docs/memory.md §3.6).
# При len(history) == 1 core.handle_user_task делает embed + search и
# подмешивает найденные чанки одним system-сообщением. true | false.
SESSION_BOOTSTRAP_ENABLED=true
# Сколько чанков подмешивать при авто-подгрузке.
SESSION_BOOTSTRAP_TOP_K=3

# --- System prompt (главный) ---
# Путь к markdown-файлу системного промпта агента, относительно корня репо.
# См. _prompts/README.md и _prompts/agent_system.md.
AGENT_SYSTEM_PROMPT_PATH=_prompts/agent_system.md

# --- Logging ---
# Уровень логов: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
# Путь к файлу логов (каталог создастся автоматически).
LOG_FILE=logs/agent.log
# Логировать ли полный контекст (payload) перед каждым LLM-запросом.
# true | false. При false в лог пишутся только размеры (messages=, tokens=).
LOG_LLM_CONTEXT=true

# --- Temporary files ---
# Директория для временных файлов (скачанные из Telegram, обработанные документы).
# Каталог создаётся автоматически при старте.
TMP_BASE_DIR=data/tmp

# --- Whisper (speech-to-text) ---
# Модель Whisper для распознавания речи (base, small, medium, large).
# См. https://github.com/SYSTRAN/faster-whisper
WHISPER_MODEL=base
# Язык для распознавания (ru, en, etc.).
WHISPER_LANGUAGE=ru

# --- Vision (image description) ---
# Модель Ollama для описания изображений.
# Рекомендации: gemma3:4b (по умолчанию), llava-phi3 (быстрее), qwen2.5-vl:7b (таблицы/диаграммы).
# См. _docs/vision-models.md
VISION_MODEL=gemma3:4b

# --- Web search ---
# Поисковик по умолчанию (duckduckgo, bing, google, brave, searxng).
# Сейчас реализован только duckduckgo, остальные — для будущих задач.
SEARCH_ENGINE_DEFAULT=duckduckgo
# Список доступных поисковиков через запятую.
SEARCH_ENGINES_AVAILABLE=duckduckgo
